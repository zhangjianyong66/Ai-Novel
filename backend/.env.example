# Copy this file to `backend/.env` for local development only.
# Never commit the real `backend/.env` file or any secret-filled variant.

# App environment: dev / prod
APP_ENV=dev

# Required in prod: portable encryption key for stored secrets (Fernet key).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Auth (cookie session)
# AUTH_DEV_FALLBACK_USER_ID: when APP_ENV=dev, allow auto-using a local user id (backward compatible).
# SECURITY (prod): make sure APP_ENV=prod; recommended to unset/empty this value in production.
# If you accidentally run production with APP_ENV=dev, this becomes an auth bypass.
AUTH_DEV_FALLBACK_USER_ID=local-user
# Optional: override signing key for session cookies (otherwise uses SECRET_ENCRYPTION_KEY in prod, or an ephemeral dev key).
AUTH_SESSION_SIGNING_KEY=
AUTH_SESSION_TTL_SECONDS=604800
AUTH_REFRESH_THRESHOLD_SECONDS=900
AUTH_ACTIVITY_TOUCH_INTERVAL_SECONDS=30
AUTH_ONLINE_WINDOW_SECONDS=300
AUTH_COOKIE_USER_ID_NAME=user_id
AUTH_COOKIE_EXPIRE_AT_NAME=session_expire_at
AUTH_COOKIE_SAMESITE=lax

# Local admin bootstrap (optional; for first deploy)
# If both AUTH_ADMIN_USER_ID and AUTH_ADMIN_PASSWORD are set, backend will create the user (if missing) and set password.
AUTH_ADMIN_USER_ID=admin
# NOTE: must be >=8 characters (example value for local dev).
AUTH_ADMIN_PASSWORD=admin-pass
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_DISPLAY_NAME=管理员
AUTH_BCRYPT_ROUNDS=12

# Default uses SQLite. For SQLite, run with a single worker: `uvicorn app.main:app --workers 1`.
# Note: relative SQLite paths are resolved under `backend/` to avoid "wrong DB" issues when starting from repo root.
DATABASE_URL=sqlite:///./ainovel.db

# Comma-separated origins for CORS (no spaces required).
# Example: http://localhost:5173,https://your.domain
CORS_ORIGINS=http://localhost:5173

# Batch generation task queue (prod recommendation: RQ + Redis).
# TASK_QUEUE_BACKEND: rq (recommended) / inline (dev/test only).
TASK_QUEUE_BACKEND=rq
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=default

# Project bundle import upload limit (bytes). Default is 50MB.
PROJECT_BUNDLE_IMPORT_MAX_BYTES=52428800

# Vector RAG (Phase 4A / Chroma) - optional
# NOTE: `chromadb` is an optional dependency; if not installed or embedding config is missing, vector_rag will fail-soft.
# These embedding settings can also be stored per-project in DB (encrypted) via the Settings UI; env acts as fallback.
# Chroma persistence directory (relative paths are resolved under `backend/`):
VECTOR_CHROMA_PERSIST_DIR=./.chroma
# OpenAI-compatible embeddings endpoint base URL (usually ends with /v1):
VECTOR_EMBEDDING_BASE_URL=http://127.0.0.1:4010/v1
VECTOR_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_API_KEY=

# Vector RAG tuning (global)
# VECTOR_BACKEND: auto / chroma / pgvector
VECTOR_BACKEND=auto

# Hybrid retrieval & rerank
VECTOR_HYBRID_ENABLED=true
VECTOR_RERANK_ENABLED=false
VECTOR_HYBRID_RRF_K=60
VECTOR_OVERFILTERING_ENABLED=true

# Retrieval limits
VECTOR_MAX_CANDIDATES=20
VECTOR_FINAL_MAX_CHUNKS=6
VECTOR_FINAL_CHAR_LIMIT=6000

# Chunking
VECTOR_CHUNK_SIZE=800
VECTOR_CHUNK_OVERLAP=120
