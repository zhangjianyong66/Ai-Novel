.envrc

# -------------------------
# Repo-root drafts / intermediate docs (keep standard OSS files)
# -------------------------
/*.md
!/README.md
!/LICENSE*
!/CONTRIBUTING.md
!/CODE_OF_CONDUCT.md
!/SECURITY.md
!/CHANGELOG.md

/错误信息.txt
/完整任务要求.txt
/tmp_*.png
/tmp_*.jpg
/tmp_*.jpeg

# Internal workflow history (keep templates/README)
plan/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*.md
issues/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*.csv

