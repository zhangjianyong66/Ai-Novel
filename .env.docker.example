# Docker Compose optional env-file template.
#
# Usage (optional):
#   docker compose --env-file .env.docker.example up -d --build
#
# Notes:
# - `docker-compose.yml` already contains safe-ish defaults; you can run without any env-file.
# - Do NOT commit a real `.env.docker` that contains secrets.
# - `SECRET_ENCRYPTION_KEY` can be left empty: container entrypoint will auto-generate and persist to the `app_data` volume.

APP_ENV=dev
LOG_LEVEL=INFO

# Postgres
POSTGRES_DB=ainovel
POSTGRES_USER=ainovel
POSTGRES_PASSWORD=ainovel
DATABASE_URL=postgresql+psycopg2://ainovel:ainovel@postgres:5432/ainovel

# Secrets (optional; auto-generated if empty)
SECRET_ENCRYPTION_KEY=
AUTH_SESSION_SIGNING_KEY=

# Vector DB (optional; persisted in `app_data` volume by default compose)
VECTOR_CHROMA_PERSIST_DIR=/data/chroma

# Auth (multi-user)
AUTH_DEV_FALLBACK_USER_ID=
AUTH_ADMIN_USER_ID=admin
AUTH_ADMIN_PASSWORD=ChangeMe123!
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_DISPLAY_NAME=管理员
AUTH_COOKIE_SAMESITE=lax

# LinuxDo OIDC (optional)
LINUXDO_OIDC_CLIENT_ID=
LINUXDO_OIDC_CLIENT_SECRET=
LINUXDO_OIDC_REDIRECT_URI=
LINUXDO_OIDC_SCOPES=openid profile email

# Optional ports (compose variable substitution)
FRONTEND_PORT=5173
BACKEND_PORT=8000
PG_PORT=5432
REDIS_PORT=6379

# Optional perf knobs
WEB_CONCURRENCY=2
RQ_WORKER_PROCESSES=1
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
RQ_QUEUE_NAME=default
PROJECT_BUNDLE_IMPORT_MAX_BYTES=52428800
