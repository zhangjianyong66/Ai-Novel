.DS_Store
Thumbs.db
Desktop.ini

.idea/
.vscode/
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
*.tsbuildinfo

# Windows reserved device names (PowerShell `> nul` can create this file)
# Cleanup (repo root):
#   Remove-Item -LiteralPath ("\\?\{0}\nul" -f (Get-Location)) -Force
/nul
*.out
*.tmp
*.cache
*.seed
